{
  "name": "tuilder",
  "version": "0.1.0",
  "description": "Interactive TUI course that teaches non-tech people to use Claude Code",
  "type": "module",
  "bin": {
    "tuilder": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npx tsx --watch src/index.tsx",
    "start": "node dist/index.js",
    "test": "vitest"
  },
  "keywords": [
    "tui",
    "cli",
    "education",
    "claude-code",
    "ink"
  ],
  "license": "MIT",
  "files": ["dist"],
  "dependencies": {
    "chalk": "^5.4.1",
    "ink": "^5.2.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.18",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
